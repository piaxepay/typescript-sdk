{
  "name": "@piaxis/sdk",
  "version": "0.2.1",
  "description": "Official JavaScript and TypeScript SDK for the Piaxis partner API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test:contract": "node ./scripts/run-contract-tests.cjs",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run typecheck && npm run test:contract && npm run build && npm run pack:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piaxepay/typescript-sdk.git"
  },
  "homepage": "https://github.com/piaxepay/typescript-sdk#readme",
  "bugs": {
    "url": "https://github.com/piaxepay/typescript-sdk/issues"
  },
  "keywords": [
    "piaxis",
    "payments",
    "escrow",
    "sdk",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.8.2"
  }
}
