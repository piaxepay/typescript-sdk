{
  "name": "@piaxis/sdk",
  "version": "0.1.0",
  "description": "Official JavaScript and TypeScript SDK for the Piaxis partner API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test:contract": "node ./scripts/run-contract-tests.cjs",
    "prepublishOnly": "npm run typecheck && npm run test:contract && npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.8.2"
  }
}
